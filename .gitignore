# ──────────────────────────────────────────────────────────────────────────
# Runtime output (generated by the application or tests)
# ──────────────────────────────────────────────────────────────────────────
logs/
reports/
errors/
screenshots/

# Flight-profile uploads (placed into logs/uploaded/ by the upload handler)
profiles/uploaded/

# Accidental Windows-path directories created when running under WSL
# (e.g. when log_directory='C:\...' is saved to app_settings.json and
# the server later runs under Linux — os.makedirs interprets the whole
# string as a single directory name).
C:\\*
"C:\\*"

# ──────────────────────────────────────────────────────────────────────────
# Runtime config (local paths + settings, generated on first run)
# ──────────────────────────────────────────────────────────────────────────
app_settings.json
sim_uut_config.json

# ──────────────────────────────────────────────────────────────────────────
# Test artifacts
# ──────────────────────────────────────────────────────────────────────────
*_results.json
test_profile.csv
pw_test.log
web_e2e.log
_pb_server.log
_pb_walkthrough_logs.txt
_sitl_debug.txt
_ui_test_uuts.json

