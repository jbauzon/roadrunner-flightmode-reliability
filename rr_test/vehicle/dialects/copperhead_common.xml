      <entry value="0" name="CH_CONTACTOR_ID_THRUSTER"/>
    </enum>
  </enums>
  <messages>
    <!-- Device power report -->
    <message id="40000" name="CH_REPORT_DEVICE_POWER_STATE">
      <description>Report power state of a device</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="char[32]" name="device_name">Name of the device to set power state</field>
      <field type="uint8_t" name="device_idx" enum="CH_DEVICE_ID">Index of the device, used for command</field>
      <field type="uint8_t" name="requested_power_state" enum="MARITIME_POWER_STATE">Requested power state</field>
      <field type="uint8_t" name="current_power_state" enum="MARITIME_POWER_STATE">Current power state</field>
      <extensions/>
      <field type="float" name="voltage" units="V">Measured voltage</field>
      <field type="float" name="current" units="A">Measured current</field>
      <field type="float" name="power" units="W">Measured power</field>
    </message>
    <!-- DCDC power report -->
    <message id="40001" name="CH_REPORT_DCDC_POWER_STATE">
      <description>Report power state of a dcdc supply</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="char[32]" name="dcdc_name">Name of the contactor to set power state</field>
      <field type="uint8_t" name="dcdc_idx" enum="CH_DCDC_ID">Index to dcdc array, used for command</field>
      <field type="uint8_t" name="requested_power_state" enum="MARITIME_POWER_STATE">Requested dcdc state</field>
      <field type="uint8_t" name="current_power_state" enum="MARITIME_POWER_STATE">Current dcdc state</field>
    </message>
    <!-- Contactor power report -->
    <message id="40002" name="CH_REPORT_CONTACTOR_POWER_STATE">
      <description>Report power state of a contactor</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="char[32]" name="contactor_name">Name of the device to set power state</field>
      <field type="uint8_t" name="contactor_idx" enum="CH_CONTACTOR_ID">Index to contactor array, used for command</field>
      <field type="uint8_t" name="requested_power_state" enum="MARITIME_POWER_STATE">Requested contactor state</field>
      <field type="uint8_t" name="current_power_state" enum="MARITIME_POWER_STATE">Current contactor state</field>
      <extensions/>
      <field type="float" name="voltage" units="V">Measured voltage</field>
      <field type="float" name="current" units="A">Measured current</field>
    </message>
  </messages>
</mavlink> 