<?xml version="1.0"?>
<mavlink>
  <include>maritime_common.xml</include>
  <dialect>111</dialect>
  <enums>
    <enum name="CH_DEVICE_ID">
      <entry value="0" name="CH_DEVICE_ID_FLS"/>
      <entry value="1" name="CH_DEVICE_ID_SPRINTNAV"/>
      <entry value="2" name="CH_DEVICE_ID_FIN_PORT_UPPER"/>
      <entry value="3" name="CH_DEVICE_ID_FIN_PORT_LOWER"/>
      <entry value="4" name="CH_DEVICE_ID_FIN_STBD_LOWER"/>
      <entry value="5" name="CH_DEVICE_ID_FIN_STBD_UPPER"/>
      <entry value="6" name="CH_DEVICE_ID_SVS"/>
      <entry value="7" name="CH_DEVICE_ID_ACOMMS"/>
      <entry value="8" name="CH_DEVICE_ID_THRUSTER"/>
      <entry value="9" name="CH_DEVICE_ID_DCB"/>
      <entry value="10" name="CH_DEVICE_ID_CSAC"/>
      <entry value="11" name="CH_DEVICE_ID_GNSS"/>
      <entry value="12" name="CH_DEVICE_ID_IRIDIUM"/>
      <entry value="13" name="CH_DEVICE_ID_ETH_ROUTER"/>
    </enum>
    <enum name="CH_DCDC_ID">
      <entry value="0" name="CH_DCDC_ID_SYSTEM_24V"/>
      <entry value="1" name="CH_DCDC_ID_PAYLOAD_24V"/>
      <entry value="2" name="CH_DCDC_ID_FINS_24V"/>
      <entry value="3" name="CH_DCDC_ID_PAYLOAD_48V"/>
    </enum>
