<?xml version="1.0"?>
<mavlink>
  <!-- See: https://pages.ghe.anduril.au/anduril/xl-operator-docs/telemetry/ADDING_NEW_METRICS.html for rules on adding new telemetry messages -->
  <dialect>109</dialect>
  <enums>
    <enum name="MARITIME_NAV_UBLOX_TELEMETRY_VALIDITY_FLAGS" bitmask="true">
      <entry value="1" name="MARITIME_NAV_UBLOX_TELEMETRY_VALIDITY_FLAGS_VALID_DATE"/> <!-- 1 = valid UTC Date -->
      <entry value="2" name="MARITIME_NAV_UBLOX_TELEMETRY_VALIDITY_FLAGS_VALID_TIME"/> <!-- 1 = valid UTC time of day  -->
      <entry value="4" name="MARITIME_NAV_UBLOX_TELEMETRY_VALIDITY_FLAGS_FULLY_RESOLVED"/> <!-- 1 = UTC time of day has been fully resolved (no seconds uncertainty). Cannot be used to check if time is completely solved. -->
      <entry value="8" name="MARITIME_NAV_UBLOX_TELEMETRY_VALIDITY_FLAGS_VALID_MAG_DEC"/> <!-- 1 = valid magnetic declination -->
    </enum>
    <enum name="MARITIME_NAV_UBLOX_TELEMETRY_GNSS_FIX_TYPE">
      <entry value="0" name="MARITIME_GNSS_NO_FIX"/>
      <entry value="1" name="MARITIME_GNSS_DEAD_RECKONING_ONLY"/>
      <entry value="2" name="MARITIME_GNSS_FIX_2D"/>
      <entry value="3" name="MARITIME_GNSS_FIX_3D"/>
      <entry value="4" name="MARITIME_GNSS_AND_DEAD_RECKONING_COMBINED"/>
      <entry value="5" name="MARITIME_GNSS_TIME_ONLY_FIX"/>
    </enum>
    <!-- GNSS fix status flags -->
    <enum name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS" bitmask="true">
      <entry value="1" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_GNSS_FIX_OK"/> <!-- 1 = valid fix (i.e within DOP & accuracy masks) -->
      <entry value="2" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_DIFF_SOLUTION"/> <!-- 1 = differential corrections were applied -->
      <!-- Bits 2, 3, 4 (values: 4, 8, 16) is a 3 bit number representing the states below, where:
        Power save mode state:
          • 0 = PSM is not active
          • 1 = Enabled (an intermediate state before
        Acquisition state
          • 2 = Acquisition
          • 3 = Tracking
          • 4 = Power Optimized Tracking
          • 5 = Inactive-->
      <entry value="4" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_PSM_STATE_B2"/>
      <entry value="8" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_PSM_STATE_B3"/>
      <entry value="16" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_PSM_STATE_B4"/>
      <entry value="32" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_HEAD_VEH_VALID"/> <!-- 1 = heading of vehicle is valid, only set if the receiver is in sensor fusion mode -->
      <!-- Bits 6, 7 (values: 64, 128) is a 2 bit number representing the carrier phase range solution status below, where:
        • 0 = no carrier phase range solution
        • 1 = carrier phase range solution with floating ambiguities
        • 2 = carrier phase range solution with fixed ambiguities -->
      <entry value="64" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_CARR_SOLUTION_B6"/>
      <entry value="128" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_CARR_SOLUTION_B7"/>
    </enum>
    <enum name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_2" bitmask="true">
      <entry value="32" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_2_CONFIRMED_AVAILABLE"/> <!-- 1 = information about UTC Date and Time of Day validity confirmation is available -->
      <entry value="64" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_2_CONFIRMED_DATE"/> <!-- 1 = UTC Date validity could be confirmed -->
      <entry value="128" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_2_CONFIRMED_TIME"/> <!-- 1 = UTC Time of Day could be confirmed -->
    </enum>
    <enum name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_3" bitmask="true">
      <entry value="1" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_3_INVALID_LLH"/> <!-- 1 = Invalid lon, lat, height and hMSL -->
      <!-- Bits 1 to 4 (values: 2, 4, 8 and 16) is a 4 bit number representing the age of the most recently received differential correction, where:
        • 0 = Not available
        • 1 = Age between 0 and 1 second
        • 2 = Age between 1 (inclusive) and 2 seconds
        • 3 = Age between 2 (inclusive) and 5 seconds
        • 4 = Age between 5 (inclusive) and 10 seconds
        • 5 = Age between 10 (inclusive) and 15 seconds
        • 6 = Age between 15 (inclusive) and 20 seconds
        • 7 = Age between 20 (inclusive) and 30 seconds
        • 8 = Age between 30 (inclusive) and 45 seconds
        • 9 = Age between 45 (inclusive) and 60 seconds
        • 10 = Age between 60 (inclusive) and 90 seconds
        • 11 = Age between 90 (inclusive) and 120 seconds
        • >=12 = Age greater or equal than 120 seconds -->
      <entry value="2" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_3_LAST_CORRECTION_AGE_B1"/>
      <entry value="4" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_3_LAST_CORRECTION_AGE_B2"/>
      <entry value="8" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_3_LAST_CORRECTION_AGE_B3"/>
      <entry value="16" name="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_3_LAST_CORRECTION_AGE_B4"/>
    </enum>
  </enums>
  <messages>
    <message id="13050" name="MARITIME_NAV_UBLOX_TELEMETRY">
      <description>Telemetry info from the Ublox GNSS</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="uint32_t" name="i_tow" units="ms">GPS time of week of the navigation epoch</field>
      <field type="uint16_t" name="year" units="y">Year (UTC)</field>
      <field type="uint8_t" name="month" units="mo">Month, range 1..12 (UTC)</field>
      <field type="uint8_t" name="day" units="d">Day of month, range 1..31 (UTC)</field>
      <field type="uint8_t" name="hour" units="h">Hour of day, range 0..23 (UTC)</field>
      <field type="uint8_t" name="min" units="min">Minute of hour, range 0..59 (UTC)</field>
      <field type="uint8_t" name="sec" units="sec">Seconds of minute, range 0..60 (UTC)</field>
      <field type="uint8_t" name="valid" enum="MARITIME_NAV_UBLOX_TELEMETRY_VALIDITY_FLAGS" display="bitmask">Validity flags</field>
      <field type="uint32_t" name="time_accuracy" units="ns">Time accuracy estimate (UTC)</field>
      <field type="int32_t" name="nano" units="ns">Fraction of second, range -1e9 .. 1e9 (UTC)</field>
      <!-- GNSSfix Type: 0 = no fix, 1 = dead reckoning only, 2 = 2D-fix, 3 = 3D-fix, 4 = GNSS + dead reckoning combined, 5 = time only fix -->
      <field type="uint8_t" name="gnss_quality_indicator" enum="MARITIME_NAV_UBLOX_TELEMETRY_GNSS_FIX_TYPE">The quality indicator of the Ublox GNSS (fix type)</field>
      <field type="uint8_t" name="flags" enum="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS" display="bitmask">Fix status flags</field>
      <field type="uint8_t" name="flags2" enum="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_2" display="bitmask">Additional flags</field>
      <field type="uint8_t" name="num_sv">Number of satellites used in Nav Solution</field>
      <field type="int32_t" name="longitude" units="degE7">Longitude, expressed as 1E-7 degrees</field>
      <field type="int32_t" name="latitude" units="degE7">Latitude, expressed as 1E-7 degrees</field>
      <field type="int32_t" name="height" units="mm">Height above ellipsoid</field>
      <field type="int32_t" name="height_msl" units="mm">Height above mean sea level</field>
      <field type="uint32_t" name="horizontal_accuracy" units="mm">Horizontal accuracy estimate</field>
      <field type="uint32_t" name="vertical_accuracy" units="mm">Vertical accuracy estimate</field>
      <field type="int32_t" name="vel_north" units="mm/s">NED north velocity</field>
      <field type="int32_t" name="vel_east" units="mm/s">NED east velocity</field>
      <field type="int32_t" name="vel_down" units="mm/s">NED down velocity</field>
      <field type="int32_t" name="ground_speed" units="mm/s">Ground Speed (2-D)</field>
      <field type="float" name="heading_motion" units="deg">Heading of motion (2-D)</field>
      <field type="uint32_t" name="speed_accuracy" units="mm/s">Speed accuracy estimate</field>
      <field type="float" name="heading_accuracy" units="deg">Heading accuracy estimate (both motion and vehicle)</field>
      <field type="float" name="pdop">Position DOP</field>
      <field type="uint8_t" name="flags3" enum="MARITIME_NAV_UBLOX_TELEMETRY_FLAGS_3" display="bitmask">Additional flags</field>
      <field type="float" name="heading_vehicle" units="deg">Heading of vehicle (2-D), this is only valid when headVehValid is set, otherwise the output is set to the heading of motion</field>
      <field type="float" name="magnetic_declination" units="deg">Magnetic declination. Only supported in ADR 4.10 and later</field>
      <field type="float" name="magnetic_dec_accuracy" units="deg">Magnetic declination accuracy. Only supported in ADR 4.10 and later</field>
    </message>
  </messages>
</mavlink>