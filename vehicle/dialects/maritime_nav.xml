<?xml version="1.0"?>
<mavlink>
  <!-- See: https://pages.ghe.anduril.au/anduril/xl-operator-docs/telemetry/ADDING_NEW_METRICS.html for rules on adding new telemetry messages -->
  <dialect>107</dialect>
  <enums>
    <enum name="MARITIME_GNSS_QUALITY_INDICATOR">
      <entry value="0" name="GNSS_QUALITY_INDICATOR_INVALID"/>
      <entry value="1" name="GNSS_QUALITY_INDICATOR_GPS_FIX"/>
      <entry value="2" name="GNSS_QUALITY_INDICATOR_DGPS_FIX"/>
      <entry value="3" name="GNSS_QUALITY_INDICATOR_PPS_FIX"/>
      <entry value="4" name="GNSS_QUALITY_INDICATOR_RTK_FIX"/>
      <entry value="5" name="GNSS_QUALITY_INDICATOR_FLOAT_RTK"/>
      <entry value="6" name="GNSS_QUALITY_INDICATOR_ESTIMATED"/>
      <entry value="7" name="GNSS_QUALITY_INDICATOR_MANUAL_INPUT"/>
      <entry value="8" name="GNSS_QUALITY_INDICATOR_SIMULATION"/>
    </enum>
  </enums>
  <messages>
    <message id="13000" name="MARITIME_NAV_SET_CSAC_TIME_CMD">
      <description>A reference time to set the Chip Scale Atomic Clock (CSAC) with in absence of valid GPS time</description>
      <field type="uint16_t" name="year">The year component yyyy of date to set (e.g. 2024)</field>
      <field type="uint8_t" name="month">The month component mm of date to set ranging between 01 and 12</field>
      <field type="uint8_t" name="day">The day component dd of date to set ranging between 01 and 31</field>
      <field type="uint8_t" name="hour">The hour component hh of the time to set ranging between 00 and 23</field>
      <field type="uint8_t" name="min">The minute component mm of the time to set ranging between 00 and 59</field>
      <field type="uint8_t" name="sec">The second component ss of the time to set ranging between 00 and 59</field>
    </message>
    <message id="13001" name="MARITIME_NAV_SVS_TELEMETRY">
      <description>Maritime svs telemetry</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="double" name="sound_velocity" units="m/s">Measured speed of sound through water</field>
      <field type="double" name="pressure" units="dbar">Measured pressure</field>
    </message>
    <message id="13002" name="MARITIME_NAV_CT_TELEMETRY">
      <description>Maritime ct telemetry</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="double" name="temperature" units="degree C">Water Temperature</field>
      <field type="double" name="conductivity" units="mS/cm">Water conductivity</field>
      <field type="double" name="salinity" units="PSU">Water salinity</field>
      <field type="double" name="density" units="kg/m^3">Water density</field>
    </message>
    <message id="13003" name="MARITIME_NAV_CSAC_TELEMETRY">
      <description>Maritime csac telemetry</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="uint16_t" name="year">date, year</field>
      <field type="uint16_t" name="month">date, month</field>
      <field type="uint16_t" name="day">date, day</field>
      <field type="uint32_t" name="pps_count">1 PPS count</field>
      <field type="uint32_t" name="fine_dac">fine dac</field>
      <field type="float" name="utc_offset" units="ns">UTC offset in nanoseconds</field>
      <field type="float" name="freq_error_est">Frequency error estimate</field>
      <field type="float" name="val_undefined">Undocumented FP Value</field>
      <field type="uint16_t" name="sats_visible">Satellites visible</field>
      <field type="uint16_t" name="sats_tracked">Satellites tracked</field>
      <field type="uint16_t" name="health_state">Systems Health Status</field>
      <field type="uint16_t" name="lock_state">State of GPS Lock</field>
      <field type="double" name="time_tag" units="sec">UTC time tag (from CSAC ZDA)</field>
    </message>
    <message id="13004" name="MARITIME_NAV_ACOMMS_USBL_TELEMETRY">
      <description>Maritime Acomms USBL aiding information telemetry</description>
      <field type="uint32_t" name="version">Message version</field>
      <field type="char[5]" name="address">Acomms device address</field>
      <field type="uint8_t" name="enable_state">Enable or disable aiding from the Acomms device (enable: 1, disable: 0)</field>
      <field type="char[16]" name="time_stamp" units="sec">UTC time tag (from Acomms aiding)</field>
      <field type="int32_t" name="source_latitude" units="degE7">Latitude of aiding position, expressed as 1E-7 degrees</field>
      <field type="int32_t" name="source_longitude" units="degE7">Longitude of aiding position, expressed as 1E-7 degrees</field>
      <field type="int32_t" name="latitude" units="degE7">Latitude, expressed as 1E-7 degrees</field>
      <field type="int32_t" name="longitude" units="degE7">Longitude, expressed as 1E-7 degrees</field>
      <field type="double" name="sd" units="m">Standard deviation</field>
      <field type="double" name="depth" units="m">Depth</field>
      <field type="uint8_t" name="in_cone">Reports if the vehicle is in the USBL cone of the host vessel (true: 1, false: 0)</field>
      <field type="double" name="cone_angle" units="deg">Angle of the vehicle relative to the host vessel</field>
      <field type="double" name="horizontal_range" units="m">Depth</field>
      <field type="uint16_t" name="status">Reported status of USBL message</field>
      <field type="uint16_t" name="payload">User defined payload</field>
    </message>
    <message id="13005" name="MARITIME_NAV_GNSS_PVT_TELEMETRY">
      <description>Maritime GNSS Position Velocity Time (PVT) telemetry</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="uint32_t" name="tow_ms" units="ms">GPS time of week from the beginning of the current week in ms</field>
      <field type="uint8_t" name="num_sv">Number of satellites used in Nav Solution</field>
      <field type="double" name="lat_deg" units="deg">Latitude in degrees</field>
      <field type="double" name="lon_deg" units="deg">Longitude in degrees</field>
      <field type="double" name="height_mm" units="mm">height in mm above ellipsoid</field>
      <field type="double" name="vel_N_mm_s" units="mm/s">North velocity in mm/s</field>
      <field type="double" name="vel_E_mm_s" units="mm/s">East velocity in mm/s</field>
      <field type="double" name="vel_D_mm_s" units="mm/s">Down velocity in mm/s</field>
      <field type="uint32_t" name="h_acc_mm" units="mm">horizontal accuracy estimate in mm</field>
      <field type="uint32_t" name="v_acc_mm" units="mm">vertical velocity estimate in mm</field>
    </message>
    <message id="13006" name="MARITIME_NAV_GNSS_DOP_TELEMETRY">
      <description>Maritime GNSS Dilution Of Precision (DOP) telemetry</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="uint32_t" name="tow_ms" units="ms">GPS time of week from the beginning of the current week in ms</field>
      <field type="uint16_t" name="g_DOP">0.01 Geometric DOP</field>
      <field type="uint16_t" name="p_DOP">0.01 Position DOP</field>
      <field type="uint16_t" name="t_DOP">0.01 Time DOP</field>
      <field type="uint16_t" name="v_DOP">0.01 Vertical DOP</field>
      <field type="uint16_t" name="h_DOP">0.01 Horizontal DOP</field>
      <field type="uint16_t" name="n_DOP">0.01 Northing DOP</field>
      <field type="uint16_t" name="e_DOP">0.01 Easting DOP</field>
    </message>
    <message id="13007" name="MARITIME_NAV_GNSS_RECEIVER_TIME_TELEMETRY">
      <description>Maritime GNSS receiver time telemetry</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="uint32_t" name="tow_ms" units="ms">GPS time of week from the beginning of the current week in ms</field>
      <field type="uint16_t" name="utc_year">UTC Year</field>
      <field type="uint8_t" name="utc_month">UTC Month</field>
      <field type="uint8_t" name="utc_day">UTC Day</field>
      <field type="uint8_t" name="utc_hour">UTC Hour</field>
      <field type="uint8_t" name="utc_min">UTC Min</field>
      <field type="uint8_t" name="utc_sec">UTC Sec</field>
      <field type="uint8_t" name="is_date_valid_bool">is date valid</field>
      <field type="uint8_t" name="is_time_valid_bool">is time valid</field>
    </message>
    <message id="13008" name="MARITIME_NAV_GNSS_FIX_DATA_TELEMETRY">
      <description>Maritime GNSS Fix data from the GGA message</description>
      <field type="uint64_t" name="timestamp_utc" units="ms">Timestamp that event occurred in Coordinated Universal Time (ms since Epoch)</field>
      <field type="double" name="latitude" units="deg">Latitude</field>
      <field type="double" name="longitude" units="deg">Longitude</field>
      <field type="uint8_t" name="gps_quality_indicator" enum="MARITIME_GNSS_QUALITY_INDICATOR">GPS Quality indicator</field>
      <field type="uint8_t" name="num_satellites">number of satellites</field>
      <field type="double" name="hdop">horizontal dilution of precision</field>
      <field type="double" name="altitude" units="m">altitude</field>
      <field type="double" name="geoid_separation" units="m">geoid separation</field>
      <field type="double" name="differential_data_age" units="sec">Age of differential GPS data</field>
      <field type="int16_t" name="differential_ref_station_id">Differential Reference Station ID/SUSBL Beacon ID. -1 if invalid</field>
    </message>
  </messages>
</mavlink>