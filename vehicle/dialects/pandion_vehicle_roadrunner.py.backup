        """
        Proportional navigation information.

        ownshipCurrentTime_ns        : Current timestamp of ownship state (type:uint64_t)
        trackTOV_ns               : Time of validity of current track (type:uint64_t)
        relPosN_ft                : Relative position North (type:float)
        relPosE_ft                : Relative position East (type:float)
        relPosD_ft                : Relative position Down (type:float)
        range_ft                  : Range relative to target (type:float)
        rangeDot_fps              : Range rate relative to target (type:float)
        zem_ft                    : Zero effort miss (type:float)
        tgo_sec                   : Time to go from target (type:float)
        status                    : 0 inactive, 1 active (type:uint8_t)
        targetEstimateValid        : If 1, target state estimate is valid (type:uint8_t)

        """
        return MAVLink_aifcs_pronav_message(ownshipCurrentTime_ns, trackTOV_ns, relPosN_ft, relPosE_ft, relPosD_ft, range_ft, rangeDot_fps, zem_ft, tgo_sec, status, targetEstimateValid)

