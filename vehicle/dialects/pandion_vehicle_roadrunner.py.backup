enums["MAV_CMD"][43001].param[4] = """Empty"""
enums["MAV_CMD"][43001].param[5] = """Empty"""
enums["MAV_CMD"][43001].param[6] = """Empty"""
enums["MAV_CMD"][43001].param[7] = """Target Altitude"""
MAV_CMD_GUIDED_CHANGE_HEADING = 43002
