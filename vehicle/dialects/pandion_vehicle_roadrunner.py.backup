    def ma_pandion_hsa_command_encode(self, counter: int, heading_type: int, heading_target_deg: float, heading_rate_of_change_dps: float, speed_type: int, speed_target_mps: float, speed_rate_of_change_mps2: float, altitude_target_m: float, altitude_rate_of_change_mps: float) -> MAVLink_ma_pandion_hsa_command_message:
        """
        (Rate: 1Hz when in HSA control mode) The following message is sent to
        request the vehicle achieve a certain heading, speed, and
        altitude.

        counter                   : Counter that increments from 0 to 255 (value wrapping back to 0) (type:uint8_t)
        heading_type              : (CURRENTLY ONLY COURSE SUPPORTED) See PANDION_MA_HEADING_TYPE, describes whether heading fields are course or heading (type:uint8_t, values:PANDION_MA_HEADING_TYPE)
        heading_target_deg        : Requested Heading, [0, 360 (not inclusive)] (type:float)
        heading_rate_of_change_dps        : (CURRENTLY UNUSED) greater than or equal to 0, 0 = max rate of change (type:float)
        speed_type                : (CURRENTLY ONLY GROUNDSPEED SUPPORTED) See PANDION_MA_SPEED_TYPE, describes whether speed fields are groundspeed or airspeed (type:uint8_t, values:PANDION_MA_SPEED_TYPE)
        speed_target_mps          : Requested Speed (must be positive) (type:float)
        speed_rate_of_change_mps2        : (CURRENTLY UNUSED) greater than or equal to 0, 0 = max rate of change (type:float)
        altitude_target_m         : Requested Altitude (type:float)
        altitude_rate_of_change_mps        : (CURRENTLY UNUSED) greater than or equal to 0, where 0 = max rate of change (type:float)

        """
        return MAVLink_ma_pandion_hsa_command_message(counter, heading_type, heading_target_deg, heading_rate_of_change_dps, speed_type, speed_target_mps, speed_rate_of_change_mps2, altitude_target_m, altitude_rate_of_change_mps)

