        param_type                : Onboard parameter type. (type:uint8_t, values:MAV_PARAM_TYPE)
        stable_crc                : Current stable crc (type:uint32_t)
        unstable_crc              : Current unstable crc (type:uint32_t)
        param_index               : Index of current param (type:uint16_t)
        confirm_send              : Confirm complete transmission or send clear cmd( 0: continue sending, 1: save params ) (type:uint8_t)

        """
        return MAVLink_pandion_rr_gcs_param_load_message(param_id, param_value, param_type, stable_crc, unstable_crc, param_index, confirm_send)

