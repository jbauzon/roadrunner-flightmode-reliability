    def pandion_rr_monarch_status_encode(self, gnss_is_from_survey: int, heading_is_from_survey: int, gnss_is_from_landing: int, ts2_mon_active: int, gnd_ldr_mon_active: int, vn_heading_en_mode: int, rzlr_config: int, selected_ins: int) -> MAVLink_pandion_rr_monarch_status_message:
        """
        RR-specific Monarch status

        gnss_is_from_survey        : GNSS measurements are currently coming from surveyed data (type:uint8_t)
        heading_is_from_survey        : Heading measurements are currently coming from surveyed data (type:uint8_t)
        gnss_is_from_landing        : GNSS measurements are currently coming from landing estimate (type:uint8_t)
        ts2_mon_active            : TS2 sensor measurements are being monitored (type:uint8_t)
        gnd_ldr_mon_active        : Landing sensor measurements are being monitored (type:uint8_t)
        vn_heading_en_mode        : NAV_HDG_EN mode used for VN heading (type:uint8_t)
        rzlr_config               : Monarch RZLR configuration, specific to vehicle application (type:uint8_t)
        selected_ins              : Selected INS (type:uint8_t, values:PANDION_RR_SELECTED_INS)

        """
