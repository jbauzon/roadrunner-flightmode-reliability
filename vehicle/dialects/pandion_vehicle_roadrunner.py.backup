enums["MAV_CMD"][31].param[5] = """Latitude"""
enums["MAV_CMD"][31].param[6] = """Longitude"""
enums["MAV_CMD"][31].param[7] = """Altitude"""
MAV_CMD_DO_FOLLOW = 32
enums["MAV_CMD"][32] = EnumEntry("MAV_CMD_DO_FOLLOW", """Begin following a target""")
