        param_index               : Index of this onboard parameter (type:uint16_t)
        param_stable              : Is this stable parameter (type:uint8_t)

        """
        self.send(self.pandion_rr_param_value_encode(param_id, param_value, param_type, param_count, param_index, param_stable), force_mavlink1=force_mavlink1)

