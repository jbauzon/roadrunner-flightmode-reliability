    def pandion_ma_inertial_state_encode(self, counter: int, time_ms: int, latitude_deg: float, longitude_deg: float, altitude_m: float, rel_altitude_m: float, velocity_x_mps: float, velocity_y_mps: float, velocity_z_mps: float, heading_valid: int, heading_deg: float) -> MAVLink_pandion_ma_inertial_state_message:
        """
        (Rate: 10Hz) The following message is used to describe the current
        inertial state of the vehicle. The position is in GPS-frame
        (right-handed, Z-up).

        counter                   : Counter that increments from 0 to 255 (value wrapping back to 0) (type:uint8_t)
        time_ms                   : Timestamp (time since system boot) (type:uint32_t)
        latitude_deg              : Latitude (type:double)
        longitude_deg             : Longitude (type:double)
        altitude_m                : WGS84 Altitude (type:float)
        rel_altitude_m            : Altitude above ground (type:float)
        velocity_x_mps            : X Groundspeed (latitude, + = north) (type:float)
        velocity_y_mps            : Y Groundspeed (longitude, + = east) (type:float)
        velocity_z_mps            : Z Groundspeed (altitude, + = down) (type:float)
        heading_valid             : If TRUE, then heading_deg is valid (type:uint8_t)
        heading_deg               : Heading (Yaw), [0, 360 (not inclusive)] [Check heading_valid before using, UINT16_MAX when invalid] (type:float)

        """
        return MAVLink_pandion_ma_inertial_state_message(counter, time_ms, latitude_deg, longitude_deg, altitude_m, rel_altitude_m, velocity_x_mps, velocity_y_mps, velocity_z_mps, heading_valid, heading_deg)

    def pandion_ma_inertial_state_send(self, counter: int, time_ms: int, latitude_deg: float, longitude_deg: float, altitude_m: float, rel_altitude_m: float, velocity_x_mps: float, velocity_y_mps: float, velocity_z_mps: float, heading_valid: int, heading_deg: float, force_mavlink1: bool = False) -> None:
        """
        (Rate: 10Hz) The following message is used to describe the current
        inertial state of the vehicle. The position is in GPS-frame
        (right-handed, Z-up).

