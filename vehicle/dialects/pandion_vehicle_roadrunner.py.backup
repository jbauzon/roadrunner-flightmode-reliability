        temperature_local_degk        : Free airstream temperature (type:double)
        static_pressure_pa        : Free airstream static pressure (type:double)
        dynamic_pressure_pa        : Free airstream dynamic pressure (type:double)
        total_pressure_pa         : Free airstream total pressure (type:double)
        press_diff_psi            : Pressure from differential sensor in PSI (type:double)
        press_abs_psi             : Pressure from absolute sensor in PSI (type:double)
        temp_diff_C               : Temperature from differential sensor in degC (type:int8_t)
        temp_abs_C                : Temperature from absolute sensor in degC (type:int8_t)
        msg_timestamp             : Cycle count (type:uint32_t)

        """
        self.send(self.air_data_sensor_status_encode(mach_number, true_air_speed_mps, pressure_altitude_m, temperature_local_degk, static_pressure_pa, dynamic_pressure_pa, total_pressure_pa, press_diff_psi, press_abs_psi, temp_diff_C, temp_abs_C, msg_timestamp), force_mavlink1=force_mavlink1)

